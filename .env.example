# Copy to .env and fill in. Do NOT commit .env (it is gitignored).

# --- Deployment ---
# "development" keeps insecure defaults working for a local demo. Set "production" on any public
# deployment: this enforces a real JWT_SECRET (the service refuses to start otherwise) and marks the
# refresh-token cookie Secure.
ENVIRONMENT=development
# Comma-separated browser origins allowed by CORS. Behind the single Traefik gateway the frontend
# and API are same-origin, so the default is usually fine; add your public URL if you split origins.
CORS_ORIGINS=http://localhost

# --- JWT authentication ---
# In production set this to a strong random value, e.g. `openssl rand -hex 32`.
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# --- Database ---
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=sentinel
DATABASE_URL=postgresql://sentinel:sentinel@postgres:5432/sentinel

# --- Assistant LLM (agent service, --profile full) ---
# Provider: "ollama" (self-hosted, default), "groq" (fast hosted, free tier), or "anthropic".
AGENT_LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5
# By default the agent talks to the bundled `ollama` container. To reuse an Ollama already
# running on the host (and skip the container), set the URL to the host gateway, e.g.:
#   OLLAMA_URL=http://host.containers.internal:11434   # Podman/Docker Desktop
# and make sure OLLAMA_MODEL matches a tag that host has pulled (e.g. qwen2.5:3b).
OLLAMA_URL=http://ollama:11434
# Groq — get a key at https://console.groq.com (OpenAI-compatible; leave blank unless used).
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Anthropic — leave blank unless used.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Neo4j / Qdrant (--profile full) ---
NEO4J_PASSWORD=sentinel
QDRANT_COLLECTION=sentinel

# --- Observability (optional) ---
LOGFIRE_TOKEN=

# --- Demo user password (seeded on startup) ---
DEMO_PASSWORD=sentinel-demo-2026

# --- Host / engine overrides (optional; defaults match `docker compose up`) ---
# Published host ports — override only if these collide with other services on the host.
HTTP_PORT=80
PREDICT_PORT=8000
POSTGRES_PORT=5432
# Full-profile (`--profile full`) host ports — override on collision (e.g. GRAPH_PORT if 8002 is taken).
AGENT_PORT=8001
GRAPH_PORT=8002
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
QDRANT_PORT=6333
# Container-engine socket Traefik reads. Default is the Docker socket; on rootless Podman use:
#   CONTAINER_SOCK=/run/user/$UID/podman/podman.sock   (and run `systemctl --user enable --now podman.socket`)
CONTAINER_SOCK=/var/run/docker.sock
